# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=cryptopulse
POSTGRES_USER=cryptopulse
POSTGRES_PASSWORD=cryptopulse_secret

# API Base URLs (public, no key needed)
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
BINANCE_BASE_URL=https://api.binance.com/api/v3
FEAR_GREED_BASE_URL=https://api.alternative.me

# Airflow
AIRFLOW_HOME=/opt/airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://cryptopulse:cryptopulse_secret@postgres:5432/airflow
AIRFLOW__CORE__FERNET_KEY=46BKJoQYlPPOexq0OhDZnIlNepKFf87WFwLt0nfd12I=
AIRFLOW__WEBSERVER__SECRET_KEY=cryptopulse_web_secret
AIRFLOW__CORE__LOAD_EXAMPLES=False

# ETL Config
LOG_LEVEL=INFO
PRICE_SPIKE_THRESHOLD=0.5
VOLUME_SPIKE_THRESHOLD=5.0
API_TIMEOUT=30
API_MAX_RETRIES=3
